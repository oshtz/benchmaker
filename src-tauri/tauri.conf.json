{
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "devPath": "http://localhost:5173",
    "distDir": "../dist"
  },
  "package": {
    "productName": "Benchmaker",
    "version": "0.1.9"
  },
  "tauri": {
    "allowlist": {
      "window": {
        "all": false,
        "close": true,
        "minimize": true,
        "maximize": true,
        "unmaximize": true,
        "startDragging": true
      },
      "http": {
        "all": false,
        "request": true,
        "scope": [
          "https://api.github.com/**",
          "https://github.com/oshtz/benchmaker/releases/download/**",
          "https://github.com/oshtz/benchmaker/releases/download/*/*",
          "https://github.com/oshtz/benchmaker/releases/**",
          "https://objects.githubusercontent.com/**"
        ]
      }
    },
    "windows": [
      {
        "title": "Benchmaker",
        "width": 1200,
        "height": 800,
        "decorations": false
      }
    ],
    "security": {
      "csp": "default-src 'self' customprotocol: asset: http://asset.localhost; connect-src 'self' https://openrouter.ai https://api.openrouter.ai https://api.github.com https://github.com https://objects.githubusercontent.com; img-src 'self' data: blob: asset: http://asset.localhost; font-src 'self' data: asset: http://asset.localhost; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; worker-src 'self' blob:; frame-src 'self' data: blob:; child-src 'self' data: blob:"
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "com.benchmaker.app",
      "icon": ["icons/icon.png", "icons/icon.ico", "icons/icon.icns"]
    }
  }
}
